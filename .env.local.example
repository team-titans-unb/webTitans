# NUNCA preencha valores reais neste arquivo — ele é commitado.
# Copie para .env.local (já está no .gitignore) e edite lá:
#   cp .env.local.example .env.local

# Cliente (expostos no bundle — anon key + URL pública é OK, RLS protege os dados)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Servidor (apenas Vercel Functions — nunca prefixar com VITE_)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
