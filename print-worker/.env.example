# Copie para .env e preencha. NUNCA commite o .env com valores reais.
# Permissão recomendada: chmod 600 .env

# Projeto Supabase (server-side; a service_role bypassa RLS).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Fila CUPS primária (preferencial). Fila de rede Wi-Fi / IPP Everywhere,
# ex.: Titans_Laser. Descubra as filas com: lpstat -p
PRINTER_NAME=

# Fila CUPS de fallback (opcional). Usada só se a primária falhar ANTES de o
# CUPS aceitar o job (failover seguro, nada impresso ainda). Ex.: fila USB
# HP_Laser_MFP_131_133_135_138. Deixe vazia para operar só com a primária.
PRINTER_NAME_FALLBACK=

# Opcionais (valores padrão abaixo).
# Intervalo entre consultas à fila, em segundos.
POLL_INTERVAL=10
# Tempo máximo de espera pela conclusão de uma impressão, em segundos.
PRINT_TIMEOUT=180
# Tempo após o qual um pedido preso em IMPRIMINDO volta para PAGO, em segundos.
STUCK_TIMEOUT=900
# Timeout (s) da checagem de alcançabilidade do destino de filas de rede
# (resolução mDNS/DNS + TCP-connect à porta IPP) feita ANTES de submeter. Curto
# de propósito: detecta a impressora Wi-Fi inalcançável em segundos e cai para a
# fila de fallback sem imprimir nada na primária.
REACHABILITY_TIMEOUT=3
# Opções `-o` passadas ao `lp`, separadas por espaço (cada token vira um
# `-o <token>`). O padrão `fit-to-page` escala cada página para a área imprimível
# preservando a proporção e auto-rotaciona páginas em paisagem, evitando que PDFs
# deitados saiam cortados. Para travar o tamanho da mídia: "fit-to-page media=A4".
# Deixe vazio para enviar sem opções (comportamento anterior).
LP_OPTIONS=fit-to-page
